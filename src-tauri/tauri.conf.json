{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yuno-learner",
  "version": "0.1.0",
  "identifier": "learner.yuno-projects.org",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "yuno-learner",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
